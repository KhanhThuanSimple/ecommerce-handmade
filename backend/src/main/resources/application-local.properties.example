# Sao chép file này thành application-local.properties và sửa giá trị máy bạn
# Chạy: mvn spring-boot:run -Dspring-boot.run.profiles=local

spring.datasource.url=jdbc:postgresql://localhost:5432/ecommerce_handmade_dev
spring.datasource.username=postgres
spring.datasource.password=YOUR_DB_PASSWORD

app.frontend-url=http://localhost:3000
app.cors-allowed-origins=http://localhost:3000

vnpay.tmn-code=YOUR_VNPAY_TMN_CODE
vnpay.hash-secret=YOUR_VNPAY_HASH_SECRET
vnpay.return-url=${app.frontend-url}/vnpay-return
vnpay.ipn-url=http://localhost:8080/api/vnpay/ipn
